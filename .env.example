# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is gitignored — never commit real secrets. This template is safe to commit.

# --- Market-data API keys (optional) -----------------------------------------
# Empty = the corresponding live-data feature stays dormant (calls fail gracefully).
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
# RapidAPI "yodish" key for Yoda-speak translation. Empty = text passes through untranslated.
YODA_API_KEY=
# LibreTranslate (self-hosted en->de) API key. Usually empty; the URL is wired up by docker-compose.
LIBRETRANSLATE_API_KEY=

# --- JWT signing secret ------------------------------------------------------
# HS256 secret, MUST be >= 32 chars. Required under the 'prod' profile (the app refuses
# to boot with the built-in dev default). Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# --- PostgreSQL --------------------------------------------------------------
# POSTGRES_PASSWORD is REQUIRED: the backend and docker-compose refuse to start without it.
# POSTGRES_DB / POSTGRES_USER are non-secret identifiers and fall back to these defaults if unset.
POSTGRES_DB=stomo_db
POSTGRES_USER=stomo_user
POSTGRES_PASSWORD=

# --- Misc --------------------------------------------------------------------
BACKEND_PORT=8080

# --- Legacy one-shot MySQL -> PostgreSQL migration (only for scripts/migrate-mysql-to-postgres.sh) ---
# Uncomment and set the OLD MySQL password if you are migrating data from a pre-PostgreSQL install.
#MYSQL_USER=stomo_user
#MYSQL_DB=stomo_db
#MYSQL_PASSWORD=
